
// O(n^3) bruteforce (time limit exceeded )


class Solution {
    public int subarraySum(int[] nums, int k) {
        int n = nums.length;
        int  count = 0;

        for(int i = 0; i < n; i++) {
            for(int j = i; j < n; j++) {
            int sum = 0;
                
                for(int l=i; l <= j; l++) {

                sum += nums[l];
                }
                if(sum == k) {
                    count++;
                }

                
            }
        }
        return count;
    }
}




//Better Approach

class Solution {
    public int subarraySum(int[] nums, int k) {
        int n = nums.length;
        int  count = 0;

        for(int i = 0; i < n; i++) {
            int sum = 0;
            for(int j = i; j < n; j++) {
                
                sum += nums[j];

                if(sum == k) {
                    count++;
                }
                
            }
        }
        return count;
    }
}



//Optimal Approach

import java.util.HashMap;

class Solution {
    public int subarraySum(int[] nums, int k) {
        HashMap<Integer, Integer> mpp = new HashMap<>();

        int preSum = 0;
        int count = 0;

        // Base case: prefix sum = 0 occurs once
        mpp.put(0, 1);

        for (int i = 0; i < nums.length; i++) {
            preSum += nums[i];

            int remove = preSum - k;

            if (mpp.containsKey(remove)) {
                count += mpp.get(remove);
            }

            mpp.put(preSum, mpp.getOrDefault(preSum, 0) + 1);
        }

        return count;
    }
}
