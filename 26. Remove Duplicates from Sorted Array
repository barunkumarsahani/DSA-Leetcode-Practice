//BruteForce (Not working for all cases , order is not sorted)
import java.util.*;

class Solution {

    public int removeDuplicates(int[] nums) {
        Set<Integer> set = new HashSet<>();
        for(int i = 0; i < nums.length; i++){
            set.add(nums[i]);
        }
        int index = 0;
        for(int n : set){
            nums[index] = n;
            index++;
        }
        return index;
    }
}
