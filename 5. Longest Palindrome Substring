// Brute Force Approach    (T.C : O(n^3) , S.C : O(1) ) 

Logic : Generate all strings then check isPalindrome or not and return longest palindrome

Code :

class Solution {
    int max = 0, start = 0, end = 0;
    public boolean isPalindrome(String s, int i, int j) {
        while(i < j) {
            char ch1 = s.charAt(i);
            char ch2 = s.charAt(j);

            if(ch1 != ch2) {
                return false;
            }
            i++;
            j--;
        }
        return true;
    }

    public String longestPalindrome(String s) {
        int n = s.length();

        for(int i = 0; i < n; i++) {
           for(int j = i; j < n; j++) {
                if(isPalindrome(s,i,j)) {
                    if((j-i+1) > max){
                        max = j-i+1;
                        start = i;
                        end = j;
                    }
                }
            }
        }
        return s.substring(start,end + 1);
    }
}





//Expand From Centre    (T.C : O(n^2) , S.C : O(1) ) 


Code :

class Solution {
    public String longestPalindrome(String s) {
        if (s == null || s.length() == 0) return "";

        int start = 0, end = 0;

        for (int i = 0; i < s.length(); i++) {

            // Odd length palindrome
            int len1 = expand(s, i, i);

            // Even length palindrome
            int len2 = expand(s, i, i + 1);

            int len = Math.max(len1, len2);

            // Update global max window
            if (len > end - start) {
                start = i - (len - 1) / 2;
                end = i + len / 2;
            }
        }

        return s.substring(start, end + 1);
    }

    private int expand(String s, int left, int right) {
        while (left >= 0 && right < s.length() &&
               s.charAt(left) == s.charAt(right)) {
            left--;
            right++;
        }
        return right - left - 1; // length
    }
}
