//Optimal Approach  ( T.C : O(n) , S.C : O(1) )   logic : “Before multiplying by 10, check if result crosses INT_MAX”

Code: 

class Solution {
    public int myAtoi(String s) {
        int i = 0, n = s.length();

        // 1. Skip whitespace   // we can use s.trim() also
        while (i < n && s.charAt(i) == ' ') i++;
        if (i == n) return 0;

        // 2. Sign
        int sign = 1;
        if (s.charAt(i) == '+' || s.charAt(i) == '-') {
            sign = (s.charAt(i) == '-') ? -1 : 1;
            i++;
        }

        // 3. Build number with overflow check
        int num = 0;

        while (i < n && Character.isDigit(s.charAt(i))) {
            int digit = s.charAt(i) - '0';

            // Overflow check
            if (num > (Integer.MAX_VALUE - digit) / 10) {
                return (sign == 1) ? Integer.MAX_VALUE : Integer.MIN_VALUE;
            }

            num = num * 10 + digit;
            i++;
        }

        return num * sign;
    }
}
