//BruteForce Approach   (T.C : NLOGN + 2N ~ n^2 ) , S.C (N )

import java.util.*;

class Solution {
    public int[][] merge(int[][] intervals) {
        int n = intervals.length;

        // Step 1: Sort by start time
        Arrays.sort(intervals, (a, b) -> Integer.compare(a[0], b[0]));

        List<int[]> ans = new ArrayList<>();

        for (int i = 0; i < n; i++) {
            int start = intervals[i][0];
            int end = intervals[i][1];

            // Skip if already merged/covered
            if (!ans.isEmpty() && end <= ans.get(ans.size() - 1)[1]) {
                continue;
            }

            // Step 2: Merge overlapping intervals
            for (int j = i + 1; j < n; j++) {
                if (intervals[j][0] <= end) {
                    end = Math.max(end, intervals[j][1]);
                } else {
                    break;
                }
            }

            ans.add(new int[]{start, end});
        }

        // Convert List -> 2D array
        return ans.toArray(new int[ans.size()][]);
    }
}




//Optimal Approach     (T.C : O(NLOGN+N) ,S.C. O(N))

import java.util.*;

class Solution {
    public int[][] merge(int[][] arr) {

        int n = arr.length;

        // Sort intervals based on start time
        Arrays.sort(arr, (a, b) -> Integer.compare(a[0], b[0]));

        List<int[]> ans = new ArrayList<>();

        for (int i = 0; i < n; i++) {

            // If result is empty OR no overlap
            if (ans.isEmpty() || arr[i][0] > ans.get(ans.size() - 1)[1]) {
                ans.add(arr[i]);
            } 
            // Overlapping case → merge
            else {
                ans.get(ans.size() - 1)[1] = 
                    Math.max(ans.get(ans.size() - 1)[1], arr[i][1]);
            }
        }

        // Convert List → 2D array
        return ans.toArray(new int[ans.size()][]);
    }
}
